{
  "scripts": {
    "build:script": "pnpm -r --filter '!lib-empty' run build",
    "git:script": "git diff-index --quiet HEAD || (git commit -m \"build. dist/\" -a --no-verify)",
    "build": "npm run build:script && npm run git:script",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "eslint": "^9.39.4"
  }
}
